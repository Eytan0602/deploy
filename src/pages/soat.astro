---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro de SOAT - Policía Nacional del Perú" bodyClass="no-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Inicio</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/dni"><i class="fas fa-id-card"></i> Validación DNI</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/licencia"><i class="fas fa-car"></i> Licencia</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/registro-vehicular"><i class="fas fa-car-side"></i> Vehículo</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <span>SOAT</span>
    </nav>

    <div id="dynamicAlert" style="display: none;"></div>

    <div class="info-box">
      <h3><i class="fas fa-info-circle"></i> Información Importante</h3>
      <ul>
        <li>Ingrese la placa del vehículo para buscar datos del SOAT automáticamente</li>
        <li>Complete todos los campos obligatorios marcados con (*)</li>
        <li>Verifique que los datos de la aseguradora y póliza sean correctos</li>
        <li>El SOAT debe estar vigente para continuar con el trámite</li>
      </ul>
    </div>

    <div class="form-card">
      <div class="form-header">
        <div class="icon">
          <i class="fas fa-file-shield"></i>
        </div>
        <h1>Registro de SOAT</h1>
        <p>Complete la información del Seguro Obligatorio de Accidentes de Tránsito</p>
      </div>

      <form id="soatForm">
        
        <div class="form-group">
          <label for="placa">
            Placa del Vehículo <span class="required">*</span>
          </label>
          <div class="input-icon" id="placaInputWrapper">
            <i class="fas fa-id-badge"></i>
            <input 
              type="text" 
              id="placa" 
              class="form-control" 
              placeholder="ABC-123 o ABC123"
              maxlength="10"
              required
              autocomplete="off"
            />
            <div class="spinner" id="soatSpinner" style="display: none;"></div>
          </div>
          <span class="error-message" id="placaError">La placa es obligatoria</span>
          <span class="success-message" id="placaSuccess" style="display: none;"><i class="fas fa-check-circle"></i> Datos del SOAT cargados correctamente</span>
        </div>

        <div class="form-group">
          <label for="aseguradora">
            Nombre de la Aseguradora <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-building"></i>
            <input 
              type="text" 
              id="aseguradora" 
              class="form-control" 
              placeholder="Ej: RIMAC, Pacífico, Mapfre..."
              required
              readonly
            />
          </div>
          <span class="error-message">La aseguradora es obligatoria</span>
        </div>

        <div class="form-group">
          <label for="numero_poliza">
            Número de Póliza <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-file-contract"></i>
            <input 
              type="text" 
              id="numero_poliza" 
              class="form-control" 
              placeholder="Ingrese el número de póliza"
              required
              readonly
            />
          </div>
          <span class="error-message">El número de póliza es obligatorio</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="fecha_inicio">
              Fecha de Inicio <span class="required">*</span>
            </label>
            <div class="input-icon">
              <i class="fas fa-calendar-check"></i>
              <input 
                type="date" 
                id="fecha_inicio" 
                class="form-control" 
                required
                readonly
                style="padding-left: 3rem;"
              />
            </div>
            <span class="error-message">La fecha de inicio es obligatoria</span>
          </div>

          <div class="form-group">
            <label for="fecha_fin">
              Fecha de Vencimiento <span class="required">*</span>
            </label>
            <div class="input-icon">
              <i class="fas fa-calendar-times"></i>
              <input 
                type="date" 
                id="fecha_fin" 
                class="form-control" 
                required
                readonly
                style="padding-left: 3rem;"
              />
            </div>
            <span class="error-message">La fecha de vencimiento es obligatoria</span>
          </div>
        </div>

        <div class="form-group">
          <label for="estado">
            Estado del SOAT <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-check-circle"></i>
            <select 
              id="estado" 
              class="form-control"
              required
              disabled
            >
              <option value="">Seleccione el estado</option>
              <option value="VIGENTE">VIGENTE</option>
              <option value="VENCIDO">VENCIDO</option>
              <option value="CANCELADO">CANCELADO</option>
            </select>
          </div>
          <span class="error-message">El estado es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="codigo_aseguradora">
            Código de Aseguradora
          </label>
          <div class="input-icon">
            <i class="fas fa-barcode"></i>
            <input 
              type="text" 
              id="codigo_aseguradora" 
              class="form-control" 
              placeholder="Código interno de la aseguradora"
              readonly
            />
          </div>
        </div>

        <div class="form-group">
          <label for="codigoSbs">
            Código SBS <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-hashtag"></i>
            <input 
              type="text" 
              id="codigoSbs" 
              class="form-control" 
              placeholder="Código SBS de 4 dígitos"
              maxlength="4"
              pattern="[0-9]{4}"
              required
              readonly
            />
          </div>
          <span class="error-message">El código SBS es obligatorio (4 dígitos)</span>
        </div>

        <div class="form-actions">
          <a href="/registro-vehicular" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i>
            Volver
          </a>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            Finalizar Registro
            <i class="fas fa-check"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase/client';

    const placaInput = document.getElementById('placa') as HTMLInputElement;
    const spinner = document.getElementById('soatSpinner');
    const statusSpan = document.getElementById('placaSuccess');
    const placaError = document.getElementById('placaError');
    const form = document.getElementById('soatForm') as HTMLFormElement;
    const alertDiv = document.getElementById('dynamicAlert');

    let typingTimer: any;
    const doneTypingInterval = 700;

    window.addEventListener('DOMContentLoaded', () => {
      const savedPlaca = sessionStorage.getItem('placa_tramite');
      if (savedPlaca) {
        placaInput.value = savedPlaca;
        consultarSoat(savedPlaca);
      }
    });

    placaInput?.addEventListener('input', () => {
      let val = placaInput.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
      if (val.length > 3) {
        val = val.substring(0, 3) + '-' + val.substring(3, 7);
      }
      placaInput.value = val;
      if (placaError) placaError.style.display = 'none';
      if (statusSpan) statusSpan.style.display = 'none';
      clearTimeout(typingTimer);
      
      const rawPlaca = val.replace('-', '');
      if (rawPlaca.length >= 6) {
        typingTimer = setTimeout(() => consultarSoat(rawPlaca), doneTypingInterval);
      }
    });

    const showAlert = (message: string, type = 'error') => {
      if (!alertDiv) return;
      const iconClass = type === 'success' ? 'fa-check-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-times-circle';
      alertDiv.innerHTML = `<div class="alert alert-${type}"><i class="fas ${iconClass}"></i><span>${message}</span></div>`;
      alertDiv.style.display = 'block';
      setTimeout(() => { alertDiv.style.display = 'none'; }, 5000);
    };

    const consultarSoat = async (placa: string) => {
      try {
        if (spinner) spinner.style.display = 'block';
        placaInput.disabled = true;

        const response = await fetch(`/api/consultar-soat/${placa}`);
        const result = await response.json();

        if (result.success && result.data) {
          const data = result.data;

          const mapeo = [
            { id: 'aseguradora', val: data.nombre_compania },
            { id: 'fecha_inicio', val: data.fecha_inicio ? convertirFecha(data.fecha_inicio) : '' },
            { id: 'fecha_fin', val: data.fecha_fin ? convertirFecha(data.fecha_fin) : '' },
            { id: 'numero_poliza', val: data.numero_poliza },
            { id: 'codigo_aseguradora', val: data.codigo_sbs_aseguradora },
            { id: 'codigoSbs', val: data.codigo_sbs_aseguradora },
            { id: 'estado', val: data.estado || 'VIGENTE' }
          ];

          mapeo.forEach(item => {
            const field = document.getElementById(item.id) as HTMLInputElement | HTMLSelectElement;
            if (field) {
              field.value = item.val || '';
              if (item.id !== 'estado') {
                if (!item.val) {
                  field.removeAttribute('readonly');
                  field.style.border = '2px solid var(--accent-yellow)';
                  field.placeholder = 'Por favor complete este campo';
                } else {
                  field.setAttribute('readonly', 'true');
                  field.style.border = '';
                }
              }
            }
          });

          if (data.estado.toUpperCase() === 'VIGENTE') {
            if (statusSpan) statusSpan.style.display = 'block';
            showAlert('Seguro SOAT VIGENTE encontrado para el vehículo', 'success');
          } else {
            showAlert(`Alerta: SOAT no vigente (Estado: ${data.estado})`, 'warning');
          }
        } else {
          throw new Error(result.message || 'SOAT no encontrado');
        }

      } catch (err: any) {
        if (placaError) {
          placaError.textContent = err.message || 'Error al validar el SOAT';
          placaError.style.display = 'block';
        }
        showAlert(err.message || 'No se pudo validar el SOAT', 'warning');
        limpiarCampos();
      } finally {
        if (spinner) spinner.style.display = 'none';
        placaInput.disabled = false;
      }
    };

    const limpiarCampos = () => {
      ['aseguradora', 'fecha_inicio', 'fecha_fin', 'numero_poliza', 'codigo_aseguradora', 'codigoSbs', 'estado'].forEach(id => {
        const field = document.getElementById(id) as HTMLInputElement;
        if (field) field.value = '';
      });
    };

    const convertirFecha = (fechaStr: string) => {
      if (!fechaStr) return '';
      if (fechaStr.includes('-')) return fechaStr; // Ya está en formato YYYY-MM-DD
      const partes = fechaStr.split('/');
      if (partes.length !== 3) return '';
      return `${partes[2]}-${partes[1].padStart(2, '0')}-${partes[0].padStart(2, '0')}`;
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const placa = placaInput.value;
      const estado = (document.getElementById('estado') as HTMLSelectElement).value;
      const fechaFin = (document.getElementById('fecha_fin') as HTMLInputElement).value;

      if (!placa) {
        alert('Placa inválida.');
        return;
      }

      if (estado.toUpperCase() !== 'VIGENTE') {
        alert('El vehículo debe contar con un SOAT en estado VIGENTE para continuar.');
        return;
      }

      const hoy = new Date().toISOString().split('T')[0];
      if (fechaFin && fechaFin < hoy) {
        alert('El seguro obligatorio SOAT se encuentra VENCIDO.');
        return;
      }

      try {
        const payload = {
          placa,
          compania: (document.getElementById('aseguradora') as HTMLInputElement).value,
          fecha_inicio: (document.getElementById('fecha_inicio') as HTMLInputElement).value,
          fecha_fin: fechaFin,
          estado,
          num_poliza: (document.getElementById('numero_poliza') as HTMLInputElement).value,
          codigo_sbs: (document.getElementById('codigoSbs') as HTMLInputElement).value
        };

        const { data, error } = await supabase
          .from('soat')
          .upsert(payload, { onConflict: 'placa' })
          .select()
          .single();

        if (error) {
          throw new Error(`Error al registrar SOAT: ${error.message}`);
        }

        // Save SOAT details in session
        sessionStorage.setItem('soat_id_tramite', data.id);
        sessionStorage.setItem('poliza_soat', payload.num_poliza);
        
        window.location.href = '/pago';

      } catch (err: any) {
        alert(`Ocurrió un error al guardar el SOAT: ${err.message}`);
      }
    });
  </script>

  <style>
    .container {
      max-width: 900px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--accent-green);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .breadcrumb a:hover {
      color: #218838;
    }

    .form-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: var(--shadow);
      animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .form-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--border-color);
    }

    .form-header .icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--accent-green), #218838);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    .form-header .icon i {
      font-size: 2rem;
      color: white;
    }

    .form-header h1 {
      font-size: 1.75rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .form-header p {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .form-group label .required {
      color: var(--error-color);
      margin-left: 0.25rem;
    }

    .input-icon {
      position: relative;
    }

    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .input-icon .spinner {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 20px;
      border: 2px solid var(--border-color);
      border-top-color: var(--accent-green);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }

    .input-icon.loading .spinner {
      display: block;
    }

    @keyframes spin {
      to { transform: translateY(-50%) rotate(360deg); }
    }

    .form-control {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 3rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      font-size: 1rem;
      background: var(--bg-primary);
      color: var(--text-primary);
      transition: all 0.3s ease;
    }

    .form-control:focus {
      outline: none;
      border-color: var(--accent-green);
      box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
    }

    .form-control.error {
      border-color: var(--error-color);
    }

    .form-control.success {
      border-color: var(--success-color);
    }

    .form-control:disabled {
      background-color: var(--bg-secondary);
      cursor: not-allowed;
      opacity: 0.6;
    }

    .error-message {
      color: var(--error-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .success-message {
      color: var(--success-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .form-control.error ~ .error-message {
      display: block;
    }

    .form-control.success ~ .success-message {
      display: block;
    }

    .alert {
      padding: 1rem 1.25rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: slideIn 0.4s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .alert-error {
      background: rgba(220, 53, 69, 0.1);
      border: 1px solid var(--error-color);
      color: var(--error-color);
    }

    .alert-success {
      background: rgba(40, 167, 69, 0.1);
      border: 1px solid var(--success-color);
      color: var(--success-color);
    }

    .alert-warning {
      background: rgba(255, 193, 7, 0.1);
      border: 1px solid var(--accent-yellow);
      color: #856404;
    }

    .alert i {
      font-size: 1.25rem;
    }

    .info-box {
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.1), rgba(33, 136, 56, 0.05));
      border: 1px solid var(--accent-green);
      border-radius: 10px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .info-box h3 {
      color: var(--accent-green);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem;
    }

    .info-box ul {
      margin-left: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 2px solid var(--border-color);
    }

    .btn {
      padding: 1rem 2rem;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      justify-content: center;
    }

    .btn-primary {
      background: var(--accent-green);
      color: white;
      flex: 1;
    }

    .btn-primary:hover {
      background: #218838;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-secondary {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 2px solid var(--border-color);
    }

    .btn-secondary:hover {
      background: var(--border-color);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 1rem;
        margin: 2rem auto;
      }

      .form-card {
        padding: 1.5rem;
      }

      .branding {
        flex-direction: column;
        text-align: center;
      }

      .logo img {
        width: 50px;
        height: 50px;
      }

      .site-title {
        font-size: 1.25rem;
      }

      .form-header h1 {
        font-size: 1.5rem;
      }

      .form-actions {
        flex-direction: column-reverse;
      }

      .btn {
        width: 100%;
      }

      .theme-toggle {
        top: 10px;
        right: 10px;
        width: 45px;
        height: 45px;
      }

      .breadcrumb {
        font-size: 0.85rem;
      }

      .form-row {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }
  </style>
</Layout>
