---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Licencia de Conducir - Policía Nacional del Perú" bodyClass="no-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Inicio</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/dni"><i class="fas fa-id-card"></i> Validación DNI</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <span>Licencia de Conducir</span>
    </nav>

    <div class="info-box">
      <h3><i class="fas fa-info-circle"></i> Información Importante</h3>
      <ul>
        <li>Ingresa el DNI del titular y los datos se completarán automáticamente</li>
        <li>Verifica que la información de tu licencia sea correcta</li>
        <li>Puedes modificar los campos si es necesario</li>
        <li>Todos los campos marcados con (*) son obligatorios</li>
      </ul>
    </div>

    <div id="dynamicAlert" style="display: none;"></div>

    <div class="form-card">
      <div class="form-header">
        <div class="icon">
          <i class="fas fa-car"></i>
        </div>
        <h1>Registro de Licencia de Conducir</h1>
        <p>Ingresa el DNI para autocompletar los datos de la licencia</p>
      </div>

      <form id="licenciaForm">
        
        <div class="form-group">
          <label for="dni">DNI del Titular <span class="required">*</span></label>
          <div class="input-icon" id="dniInputWrapper">
            <i class="fas fa-id-card-alt"></i>
            <input type="text" id="dni" class="form-control" placeholder="12345678" maxlength="8" pattern="[0-9]{8}" required autocomplete="off" />
            <div class="spinner" id="licenciaSpinner" style="display: none;"></div>
          </div>
          <span class="error-message" id="dniError">El DNI debe tener 8 dígitos</span>
          <span class="success-message" id="dniSuccess"><i class="fas fa-check-circle"></i> Datos cargados correctamente</span>
        </div>

        <div class="form-group">
          <label for="nombre_completo">Nombre Completo <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-user"></i>
            <input type="text" id="nombre_completo" class="form-control" placeholder="Juan Pérez García" required />
          </div>
          <span class="error-message">El nombre completo es obligatorio</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="numero_licencia">Número de Licencia <span class="required">*</span></label>
            <div class="input-icon">
              <i class="fas fa-hashtag"></i>
              <input type="text" id="numero_licencia" class="form-control" placeholder="Q08880689" required />
            </div>
            <span class="error-message">El número de licencia es obligatorio</span>
          </div>

          <div class="form-group">
            <label for="categoria">Categoría <span class="required">*</span></label>
            <div class="input-icon">
              <i class="fas fa-list"></i>
              <input type="text" id="categoria" class="form-control" placeholder="A-I, B-I, etc." required />
            </div>
            <span class="error-message">La categoría es obligatoria</span>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="fecha_expedicion">Fecha de Emisión <span class="required">*</span></label>
            <div class="input-icon">
              <i class="fas fa-calendar-check"></i>
              <input type="date" id="fecha_expedicion" class="form-control" required style="padding-left: 3rem;" />
            </div>
            <span class="error-message">La fecha de emisión es obligatoria</span>
          </div>

          <div class="form-group">
            <label for="fecha_vencimiento">Fecha de Vencimiento <span class="required">*</span></label>
            <div class="input-icon">
              <i class="fas fa-calendar-times"></i>
              <input type="date" id="fecha_vencimiento" class="form-control" required style="padding-left: 3rem;" />
            </div>
            <span class="error-message">La fecha de vencimiento es obligatoria</span>
          </div>
        </div>

        <div class="form-group">
          <label for="estado">Estado de la Licencia</label>
          <div class="input-icon">
            <i class="fas fa-check-circle"></i>
            <input type="text" id="estado" value="ACTIVA" class="form-control" />
          </div>
        </div>

        <div class="form-group">
          <label for="restricciones">Restricciones</label>
          <div class="input-icon">
            <i class="fas fa-exclamation-triangle"></i>
            <input type="text" id="restricciones" class="form-control" placeholder="Ninguna" />
          </div>
        </div>

        <div class="form-actions">
          <a href="/dni" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver
          </a>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            Siguiente <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase/client';

    const dniInput = document.getElementById('dni') as HTMLInputElement;
    const spinner = document.getElementById('licenciaSpinner');
    const dniError = document.getElementById('dniError');
    const dniSuccess = document.getElementById('dniSuccess');
    const form = document.getElementById('licenciaForm') as HTMLFormElement;
    const alertDiv = document.getElementById('dynamicAlert');

    let typingTimer: any;
    const doneTypingInterval = 600;

    // Auto-load DNI from sessionStorage if available
    window.addEventListener('DOMContentLoaded', () => {
      const savedDni = sessionStorage.getItem('dni_tramite');
      if (savedDni) {
        dniInput.value = savedDni;
        consultarLicencia(savedDni);
      }
    });

    dniInput?.addEventListener('input', () => {
      dniInput.value = dniInput.value.replace(/\D/g, ''); // numbers only
      if (dniError) dniError.style.display = 'none';
      if (dniSuccess) dniSuccess.style.display = 'none';
      clearTimeout(typingTimer);
      
      if (dniInput.value.length === 8) {
        typingTimer = setTimeout(() => consultarLicencia(dniInput.value), doneTypingInterval);
      }
    });

    const showAlert = (message: string, type = 'error') => {
      if (!alertDiv) return;
      const iconClass = type === 'success' ? 'fa-check-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-times-circle';
      alertDiv.innerHTML = `<div class="alert alert-${type}"><i class="fas ${iconClass}"></i><span>${message}</span></div>`;
      alertDiv.style.display = 'block';
      setTimeout(() => { alertDiv.style.display = 'none'; }, 5000);
    };

    const consultarLicencia = async (dni: string) => {
      try {
        if (spinner) spinner.style.display = 'block';
        dniInput.disabled = true;

        const response = await fetch(`/api/consultar-licencia/${dni}`);
        const result = await response.json();

        if (result.success && result.data) {
          const data = result.data;
          (document.getElementById('nombre_completo') as HTMLInputElement).value = data.nombre_completo || '';
          const lic = data.licencia || {};

          const mapeo = [
            { id: 'nombre_completo', val: data.nombre_completo },
            { id: 'numero_licencia', val: lic.numero },
            { id: 'categoria', val: lic.categoria },
            { id: 'fecha_expedicion', val: lic.fecha_expedicion ? convertirFecha(lic.fecha_expedicion) : '' },
            { id: 'fecha_vencimiento', val: lic.fecha_vencimiento ? convertirFecha(lic.fecha_vencimiento) : '' },
            { id: 'estado', val: lic.estado || 'ACTIVA' },
            { id: 'restricciones', val: lic.restricciones || 'Ninguna' }
          ];

          mapeo.forEach(item => {
            const field = document.getElementById(item.id) as HTMLInputElement;
            if (field) {
              field.value = item.val || '';
              if (!item.val) {
                field.removeAttribute('readonly');
                field.style.border = '2px solid var(--accent-yellow)';
                field.placeholder = 'Por favor complete este campo';
              } else {
                field.setAttribute('readonly', 'true');
                field.style.border = '';
              }
            }
          });

          if (dniSuccess) dniSuccess.style.display = 'block';
          showAlert('Datos de licencia cargados correctamente', 'success');

        } else {
          throw new Error(result.message || 'Licencia no encontrada');
        }

      } catch (err: any) {
        if (dniError) {
          dniError.textContent = err.message || 'Error al validar la licencia';
          dniError.style.display = 'block';
        }
        showAlert(err.message || 'No se encontraron datos de la licencia', 'warning');
        limpiarCampos();
      } finally {
        if (spinner) spinner.style.display = 'none';
        dniInput.disabled = false;
      }
    };

    const convertirFecha = (fechaStr: string) => {
      if (!fechaStr) return '';
      const partes = fechaStr.split('/');
      if (partes.length !== 3) return '';
      return `${partes[2]}-${partes[1].padStart(2, '0')}-${partes[0].padStart(2, '0')}`;
    };

    const limpiarCampos = () => {
      ['nombre_completo', 'numero_licencia', 'categoria', 'fecha_expedicion', 'fecha_vencimiento', 'estado', 'restricciones'].forEach(id => {
        const field = document.getElementById(id) as HTMLInputElement;
        if (field) field.value = '';
      });
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const dni = dniInput.value;
      const estado = (document.getElementById('estado') as HTMLInputElement).value;
      const fechaVencimiento = (document.getElementById('fecha_vencimiento') as HTMLInputElement).value;

      if (!dni || dni.length !== 8) {
        alert('DNI inválido.');
        return;
      }

      if (estado.toUpperCase() !== 'ACTIVA') {
        alert('El titular debe contar con una licencia en estado ACTIVA para continuar.');
        return;
      }

      const hoy = new Date().toISOString().split('T')[0];
      if (fechaVencimiento && fechaVencimiento < hoy) {
        alert('La licencia de conducir se encuentra VENCIDA.');
        return;
      }

      try {
        const payload = {
          dni,
          nombre_completo: (document.getElementById('nombre_completo') as HTMLInputElement).value,
          numero_licencia: (document.getElementById('numero_licencia') as HTMLInputElement).value,
          categoria: (document.getElementById('categoria') as HTMLInputElement).value,
          fecha_expedicion: (document.getElementById('fecha_expedicion') as HTMLInputElement).value,
          fecha_vencimiento: fechaVencimiento,
          estado,
          restricciones: (document.getElementById('restricciones') as HTMLInputElement).value
        };

        const { error } = await supabase
          .from('licencias')
          .insert(payload);

        if (error) {
          throw new Error(`Error al registrar licencia: ${error.message}`);
        }

        window.location.href = '/registro-vehicular';

      } catch (err: any) {
        alert(`Ocurrió un error al guardar la licencia: ${err.message}`);
      }
    });
  </script>

  <style>
    .container {
      max-width: 900px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--accent-green);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .breadcrumb a:hover {
      color: #218838;
    }

    .form-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: var(--shadow);
      animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .form-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--border-color);
    }

    .form-header .icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--accent-green), #218838);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    .form-header .icon i {
      font-size: 2rem;
      color: white;
    }

    .form-header h1 {
      font-size: 1.75rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .form-header p {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .form-group label .required {
      color: var(--error-color);
      margin-left: 0.25rem;
    }

    .input-icon {
      position: relative;
    }

    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .input-icon .spinner {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 20px;
      border: 2px solid var(--border-color);
      border-top-color: var(--accent-green);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }

    .input-icon.loading .spinner {
      display: block;
    }

    @keyframes spin {
      to { transform: translateY(-50%) rotate(360deg); }
    }

    .form-control {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 3rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      font-size: 1rem;
      background: var(--bg-primary);
      color: var(--text-primary);
      transition: all 0.3s ease;
    }

    .form-control:focus {
      outline: none;
      border-color: var(--accent-green);
      box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
    }

    .form-control.error {
      border-color: var(--error-color);
    }

    .form-control.success {
      border-color: var(--success-color);
    }

    .form-control:disabled {
      background-color: var(--bg-secondary);
      cursor: not-allowed;
      opacity: 0.6;
    }

    .error-message {
      color: var(--error-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .success-message {
      color: var(--success-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .form-control.error ~ .error-message {
      display: block;
    }

    .form-control.success ~ .success-message {
      display: block;
    }

    .alert {
      padding: 1rem 1.25rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: slideIn 0.4s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .alert-error {
      background: rgba(220, 53, 69, 0.1);
      border: 1px solid var(--error-color);
      color: var(--error-color);
    }

    .alert-success {
      background: rgba(40, 167, 69, 0.1);
      border: 1px solid var(--success-color);
      color: var(--success-color);
    }

    .alert-warning {
      background: rgba(255, 193, 7, 0.1);
      border: 1px solid var(--accent-yellow);
      color: #856404;
    }

    .alert i {
      font-size: 1.25rem;
    }

    .info-box {
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.1), rgba(33, 136, 56, 0.05));
      border: 1px solid var(--accent-green);
      border-radius: 10px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .info-box h3 {
      color: var(--accent-green);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem;
    }

    .info-box ul {
      margin-left: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 2px solid var(--border-color);
    }

    .btn {
      padding: 1rem 2rem;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      justify-content: center;
    }

    .btn-primary {
      background: var(--accent-green);
      color: white;
      flex: 1;
    }

    .btn-primary:hover {
      background: #218838;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-secondary {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 2px solid var(--border-color);
    }

    .btn-secondary:hover {
      background: var(--border-color);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 1rem;
        margin: 2rem auto;
      }

      .form-card {
        padding: 1.5rem;
      }

      .branding {
        flex-direction: column;
        text-align: center;
      }

      .logo img {
        width: 50px;
        height: 50px;
      }

      .site-title {
        font-size: 1.25rem;
      }

      .form-header h1 {
        font-size: 1.5rem;
      }

      .form-actions {
        flex-direction: column-reverse;
      }

      .btn {
        width: 100%;
      }

      .theme-toggle {
        top: 10px;
        right: 10px;
        width: 45px;
        height: 45px;
      }

      .breadcrumb {
        font-size: 0.85rem;
      }

      .form-row {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }
  </style>
</Layout>
