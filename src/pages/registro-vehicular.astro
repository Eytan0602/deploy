---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro Vehicular - Policía Nacional del Perú" bodyClass="no-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Inicio</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/dni"><i class="fas fa-id-card"></i> Validación DNI</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <a href="/licencia"><i class="fas fa-car"></i> Licencia</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <span>Registro Vehicular</span>
    </nav>

    <div id="dynamicAlert" style="display: none;"></div>

    <div class="info-box">
      <h3><i class="fas fa-info-circle"></i> Información Importante</h3>
      <ul>
        <li>Ingrese la placa del vehículo para buscar datos automáticamente</li>
        <li>Complete todos los campos obligatorios marcados con (*)</li>
        <li>Verifique que el número de motor, serie y VIN sean correctos</li>
        <li>La foto del vehículo es obligatoria para continuar</li>
      </ul>
    </div>

    <div class="form-card">
      <div class="form-header">
        <div class="icon">
          <i class="fas fa-car-side"></i>
        </div>
        <h1>Registro Vehicular</h1>
        <p>Complete la información del vehículo para el trámite</p>
      </div>

      <form id="vehiculoForm">
        
        <div class="form-group">
          <label for="placa">
            Placa del Vehículo <span class="required">*</span>
          </label>
          <div class="input-icon" id="placaInputWrapper">
            <i class="fas fa-id-badge"></i>
            <input 
              type="text" 
              id="placa" 
              class="form-control" 
              placeholder="ABC-123 o ABC123"
              maxlength="10"
              required
              autocomplete="off"
            />
            <div class="spinner" id="placaSpinner" style="display: none;"></div>
          </div>
          <span class="error-message" id="placaError">La placa es obligatoria</span>
          <span class="success-message" id="placaSuccess"><i class="fas fa-check-circle"></i> Datos cargados correctamente</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="marca">
              Marca <span class="required">*</span>
            </label>
            <div class="input-icon">
              <i class="fas fa-trademark"></i>
              <input 
                type="text" 
                id="marca" 
                class="form-control" 
                placeholder="Toyota, Honda, etc."
                required
                readonly
              />
            </div>
            <span class="error-message">La marca es obligatoria</span>
          </div>

          <div class="form-group">
            <label for="modelo">
              Modelo <span class="required">*</span>
            </label>
            <div class="input-icon">
              <i class="fas fa-car"></i>
              <input 
                type="text" 
                id="modelo" 
                class="form-control" 
                placeholder="Corolla, Civic, etc."
                required
                readonly
              />
            </div>
            <span class="error-message">El modelo es obligatorio</span>
          </div>
        </div>

        <div class="form-group">
          <label for="anio">
            Año de Fabricación
          </label>
          <div class="input-icon">
            <i class="fas fa-calendar-alt"></i>
            <input 
              type="number" 
              id="anio" 
              class="form-control" 
              placeholder="2020"
              min="1900"
              max="2025"
              readonly
            />
          </div>
        </div>

        <div class="form-group">
          <label for="color">
            Color del Vehículo
          </label>
          <div class="input-icon">
            <i class="fas fa-palette"></i>
            <input 
              type="text" 
              id="color" 
              class="form-control" 
              placeholder="Blanco, Negro, etc."
              readonly
            />
          </div>
        </div>

        <div class="form-group">
          <label for="motor">
            Número de Motor <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-cog"></i>
            <input 
              type="text" 
              id="motor" 
              class="form-control" 
              placeholder="Ingrese el número de motor"
              required
              readonly
            />
          </div>
          <span class="error-message">El número de motor es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="serie">
            Número de Serie <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-barcode"></i>
            <input 
              type="text" 
              id="serie" 
              class="form-control" 
              placeholder="Ingrese el número de serie"
              required
              readonly
            />
          </div>
          <span class="error-message">El número de serie es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="vin">
            Número VIN <span class="required">*</span>
          </label>
          <div class="input-icon">
            <i class="fas fa-fingerprint"></i>
            <input 
              type="text" 
              id="vin" 
              class="form-control" 
              placeholder="17 caracteres alfanuméricos"
              maxlength="17"
              required
              readonly
            />
          </div>
          <span class="error-message">El número VIN debe tener 17 caracteres</span>
        </div>

        <div class="form-group">
          <label>
            Foto del Vehículo <span class="required">*</span>
          </label>
          <div class="upload-section" id="uploadSection">
            <i class="fas fa-camera"></i>
            <p>Suba una foto del vehículo para verificación</p>
            <div class="file-input-wrapper" id="fileInputWrapper">
              <button type="button" class="btn btn-upload" id="uploadBtn">
                <i class="fas fa-upload"></i>
                Seleccionar Foto
              </button>
              <input 
                type="file" 
                id="fotoVerificacion" 
                accept="image/*"
                capture="environment"
                style="display: none;"
              />
            </div>
            <div class="file-preview" id="filePreview" style="display: none;">
              <img id="previewImage" src="" alt="Vista previa">
              <div class="file-info">
                <div>
                  <span class="file-name" id="fileName"></span>
                  <span class="file-size" id="fileSize"></span>
                </div>
                <button type="button" class="btn-remove-photo" id="btnRemovePhoto">
                  <i class="fas fa-times"></i>
                  Eliminar foto
                </button>
              </div>
            </div>
          </div>
        </div>

        <input type="hidden" id="fotoVerificacionBase64" name="fotoVerificacionBase64" />

        <div class="form-actions">
          <a href="/licencia" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i>
            Volver
          </a>
          <button type="submit" class="btn btn-primary" id="submitBtn">
            Siguiente
            <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase/client';

    const placaInput = document.getElementById('placa') as HTMLInputElement;
    const spinner = document.getElementById('placaSpinner');
    const statusSpan = document.getElementById('placaSuccess');
    const placaError = document.getElementById('placaError');
    const form = document.getElementById('vehiculoForm') as HTMLFormElement;
    const alertDiv = document.getElementById('dynamicAlert');

    const uploadBtn = document.getElementById('uploadBtn');
    const fileInput = document.getElementById('fotoVerificacion') as HTMLInputElement;
    const previewContainer = document.getElementById('filePreview');
    const previewImage = document.getElementById('previewImage') as HTMLImageElement;
    const base64Input = document.getElementById('fotoVerificacionBase64') as HTMLInputElement;
    const removeFileBtn = document.getElementById('btnRemovePhoto');
    const fileNameText = document.getElementById('fileName');
    const fileSizeText = document.getElementById('fileSize');
    const fileInputWrapper = document.getElementById('fileInputWrapper');

    let typingTimer: any;
    const doneTypingInterval = 700;

    // Autoload last values
    window.addEventListener('DOMContentLoaded', () => {
      const savedPlaca = sessionStorage.getItem('placa_tramite');
      if (savedPlaca) {
        placaInput.value = savedPlaca;
        consultarVehiculo(savedPlaca);
      }
    });

    placaInput?.addEventListener('input', () => {
      // Format as ABC-123 or ABC1234
      let val = placaInput.value.toUpperCase().replace(/[^A-Z0-9]/g, '');
      
      if (val.length > 3) {
        val = val.substring(0, 3) + '-' + val.substring(3, 7);
      }
      
      placaInput.value = val;
      if (placaError) placaError.style.display = 'none';
      if (statusSpan) statusSpan.style.display = 'none';
      clearTimeout(typingTimer);
      
      const rawPlaca = val.replace('-', '');
      if (rawPlaca.length >= 6) {
        typingTimer = setTimeout(() => consultarVehiculo(rawPlaca), doneTypingInterval);
      }
    });

    const showAlert = (message: string, type = 'error') => {
      if (!alertDiv) return;
      const iconClass = type === 'success' ? 'fa-check-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-times-circle';
      alertDiv.innerHTML = `<div class="alert alert-${type}"><i class="fas ${iconClass}"></i><span>${message}</span></div>`;
      alertDiv.style.display = 'block';
      setTimeout(() => { alertDiv.style.display = 'none'; }, 5000);
    };

    const consultarVehiculo = async (placa: string) => {
      try {
        if (spinner) spinner.style.display = 'block';
        placaInput.disabled = true;

        const response = await fetch(`/api/consultar-vehiculo/${placa}`);
        const result = await response.json();

        if (result.success && result.data) {
          const data = result.data;
          
          (document.getElementById('marca') as HTMLInputElement).value = data.marca || '';
          (document.getElementById('modelo') as HTMLInputElement).value = data.modelo || '';
          (document.getElementById('anio') as HTMLInputElement).value = data.anio || '';
          (document.getElementById('color') as HTMLInputElement).value = data.color || '';
          (document.getElementById('motor') as HTMLInputElement).value = data.motor || '';
          (document.getElementById('serie') as HTMLInputElement).value = data.serie || '';
          (document.getElementById('vin') as HTMLInputElement).value = data.vin || '';

          if (statusSpan) statusSpan.style.display = 'block';
          showAlert('Vehículo verificado exitosamente en la SUNARP', 'success');
        } else {
          throw new Error(result.message || 'Vehículo no encontrado');
        }

      } catch (err: any) {
        if (placaError) {
          placaError.textContent = err.message || 'Error al verificar el vehículo';
          placaError.style.display = 'block';
        }
        showAlert(err.message || 'No se pudo verificar el vehículo', 'warning');
        limpiarCampos();
      } finally {
        if (spinner) spinner.style.display = 'none';
        placaInput.disabled = false;
      }
    };

    const limpiarCampos = () => {
      ['marca', 'modelo', 'anio', 'color', 'motor', 'serie', 'vin'].forEach(id => {
        const field = document.getElementById(id) as HTMLInputElement;
        if (field) field.value = '';
      });
    };

    // Upload files converter
    uploadBtn?.addEventListener('click', () => {
      fileInput?.click();
    });

    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (event) => {
          const base64 = event.target?.result as string;
          
          if (base64Input) base64Input.value = base64;
          if (previewImage) previewImage.src = base64;
          if (fileNameText) fileNameText.textContent = file.name;
          if (fileSizeText) fileSizeText.textContent = formatBytes(file.size);
          
          if (previewContainer) previewContainer.style.display = 'block';
          if (fileInputWrapper) fileInputWrapper.style.display = 'none';
        };
        reader.readAsDataURL(file);
      }
    });

    removeFileBtn?.addEventListener('click', () => {
      fileInput.value = '';
      if (base64Input) base64Input.value = '';
      if (previewImage) previewImage.src = '';
      if (previewContainer) previewContainer.style.display = 'none';
      if (fileInputWrapper) fileInputWrapper.style.display = 'block';
    });

    const formatBytes = (bytes: number) => {
      if (bytes === 0) return '0 Bytes';
      const k = 1024;
      const sizes = ['Bytes', 'KB', 'MB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const placa = placaInput.value;
      const foto = base64Input.value;

      if (!placa || placa.length < 6) {
        alert('Placa inválida.');
        return;
      }

      if (!foto) {
        alert('Debe cargar una fotografía de verificación del vehículo.');
        return;
      }

      try {
        const payload = {
          placa,
          marca: (document.getElementById('marca') as HTMLInputElement).value,
          modelo: (document.getElementById('modelo') as HTMLInputElement).value,
          anio: parseInt((document.getElementById('anio') as HTMLInputElement).value),
          color: (document.getElementById('color') as HTMLInputElement).value,
          motor: (document.getElementById('motor') as HTMLInputElement).value,
          serie: (document.getElementById('serie') as HTMLInputElement).value,
          vin: (document.getElementById('vin') as HTMLInputElement).value,
          foto_verificacion: foto
        };

        const { error } = await supabase
          .from('vehiculos')
          .upsert(payload);

        if (error) {
          throw new Error(`Error al registrar vehículo: ${error.message}`);
        }

        // Save to session
        sessionStorage.setItem('placa_tramite', placa);
        sessionStorage.setItem('modelo_vehiculo', `${payload.marca} ${payload.modelo}`);
        sessionStorage.setItem('color_vehiculo', payload.color);
        
        window.location.href = '/soat';

      } catch (err: any) {
        alert(`Ocurrió un error al guardar el vehículo: ${err.message}`);
      }
    });
  </script>

  <style>
    .container {
      max-width: 900px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--accent-green);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .breadcrumb a:hover {
      color: #218838;
    }

    .form-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: var(--shadow);
      animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .form-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--border-color);
    }

    .form-header .icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--accent-green), #218838);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    .form-header .icon i {
      font-size: 2rem;
      color: white;
    }

    .form-header h1 {
      font-size: 1.75rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .form-header p {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .form-group label .required {
      color: var(--error-color);
      margin-left: 0.25rem;
    }

    .input-icon {
      position: relative;
    }

    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
      font-size: 1.1rem;
    }

    .input-icon .spinner {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      width: 20px;
      height: 20px;
      border: 2px solid var(--border-color);
      border-top-color: var(--accent-green);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      display: none;
    }

    .input-icon.loading .spinner {
      display: block;
    }

    @keyframes spin {
      to { transform: translateY(-50%) rotate(360deg); }
    }

    .form-control {
      width: 100%;
      padding: 0.875rem 1rem 0.875rem 3rem;
      border: 2px solid var(--border-color);
      border-radius: 8px;
      font-size: 1rem;
      background: var(--bg-primary);
      color: var(--text-primary);
      transition: all 0.3s ease;
    }

    .form-control:focus {
      outline: none;
      border-color: var(--accent-green);
      box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
    }

    .form-control.error {
      border-color: var(--error-color);
    }

    .form-control.success {
      border-color: var(--success-color);
    }

    .form-control:disabled {
      background-color: var(--bg-secondary);
      cursor: not-allowed;
      opacity: 0.6;
    }

    .error-message {
      color: var(--error-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .success-message {
      color: var(--success-color);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      display: none;
      font-weight: 500;
    }

    .form-control.error ~ .error-message {
      display: block;
    }

    .form-control.success ~ .success-message {
      display: block;
    }

    .alert {
      padding: 1rem 1.25rem;
      border-radius: 8px;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: slideIn 0.4s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .alert-error {
      background: rgba(220, 53, 69, 0.1);
      border: 1px solid var(--error-color);
      color: var(--error-color);
    }

    .alert-success {
      background: rgba(40, 167, 69, 0.1);
      border: 1px solid var(--success-color);
      color: var(--success-color);
    }

    .alert-warning {
      background: rgba(255, 193, 7, 0.1);
      border: 1px solid var(--accent-yellow);
      color: #856404;
    }

    .alert i {
      font-size: 1.25rem;
    }

    .info-box {
      background: linear-gradient(135deg, rgba(40, 167, 69, 0.1), rgba(33, 136, 56, 0.05));
      border: 1px solid var(--accent-green);
      border-radius: 10px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .info-box h3 {
      color: var(--accent-green);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1.1rem;
    }

    .info-box ul {
      margin-left: 1.5rem;
      color: var(--text-secondary);
      line-height: 1.8;
    }

    .form-actions {
      display: flex;
      gap: 1rem;
      justify-content: space-between;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 2px solid var(--border-color);
    }

    .btn {
      padding: 1rem 2rem;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      justify-content: center;
    }

    .btn-primary {
      background: var(--accent-green);
      color: white;
      flex: 1;
    }

    .btn-primary:hover {
      background: #218838;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-secondary {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 2px solid var(--border-color);
    }

    .btn-secondary:hover {
      background: var(--border-color);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    /* ===== UPLOAD SECTION STYLES ===== */
    .upload-section {
      background: var(--bg-secondary);
      border: 2px dashed var(--border-color);
      border-radius: 10px;
      padding: 2rem;
      text-align: center;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
      width: 100%;
    }

    .upload-section:hover {
      border-color: var(--accent-green);
      background: rgba(40, 167, 69, 0.05);
    }

    .upload-section i {
      font-size: 3rem;
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .upload-section p {
      color: var(--text-secondary);
      margin-bottom: 1rem;
    }

    .file-input-wrapper {
      position: relative;
      display: inline-block;
      width: 100%;
    }

    .file-input-wrapper input[type="file"] {
      position: absolute;
      left: 0;
      top: 0;
      opacity: 0;
      width: 100%;
      height: 100%;
      cursor: pointer;
    }

    .btn-upload {
      background: var(--accent-green);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: all 0.3s ease;
    }

    .btn-upload:hover {
      background: #218838;
      transform: translateY(-2px);
    }

    .photo-preview {
      width: 100%;
      max-height: 250px;
      object-fit: contain;
      border-radius: 8px;
      border: 1px solid var(--border-color);
      margin-top: 1rem;
      display: none;
    }

    .photo-preview.show {
      display: block;
    }

    @media (max-width: 768px) {
      .container {
        padding: 0 1rem;
        margin: 2rem auto;
      }

      .form-card {
        padding: 1.5rem;
      }

      .branding {
        flex-direction: column;
        text-align: center;
      }

      .logo img {
        width: 50px;
        height: 50px;
      }

      .site-title {
        font-size: 1.25rem;
      }

      .form-header h1 {
        font-size: 1.5rem;
      }

      .form-actions {
        flex-direction: column-reverse;
      }

      .btn {
        width: 100%;
      }

      .theme-toggle {
        top: 10px;
        right: 10px;
        width: 45px;
        height: 45px;
      }

      .breadcrumb {
        font-size: 0.85rem;
      }

      .form-row {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }
  </style>
</Layout>
