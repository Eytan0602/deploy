---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Validación DNI - Policía Nacional del Perú" bodyClass="no-hero">
  <!-- Face API para validación de rostros -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@vladmandic/face-api/dist/face-api.min.js"></script>
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/"><i class="fas fa-home"></i> Inicio</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <span>Validación DNI</span>
    </nav>

    <div class="info-box">
      <h3><i class="fas fa-info-circle"></i> Información Importante</h3>
      <ul>
        <li>Ingresa tu DNI de 8 dígitos y los datos se completarán automáticamente</li>
        <li>Verifica que tus datos sean correctos antes de continuar</li>
        <li>Todos los campos son obligatorios</li>
        <li>El proceso tomará aproximadamente 5 minutos</li>
      </ul>
    </div>

    <div class="form-card">
      <div class="form-header">
        <div class="icon">
          <i class="fas fa-id-card"></i>
        </div>
        <h1>Validación de Identidad</h1>
        <p>Ingresa tu DNI para autocompletar los datos</p>
      </div>

      <form id="dniForm">
        
        <div class="form-group">
          <label for="dni">DNI <span class="required">*</span></label>
          <div class="input-icon" id="dniInputWrapper">
            <i class="fas fa-id-card"></i>
            <input type="text" id="dni" class="form-control" placeholder="12345678" maxlength="8" pattern="[0-9]{8}" required autocomplete="off" />
            <div class="spinner" id="dniSpinner" style="display: none;"></div>
          </div>
          <span class="error-message" id="dniError">El DNI debe tener 8 dígitos</span>
          <span class="success-message" id="dniSuccess"><i class="fas fa-check-circle"></i> Datos cargados correctamente</span>
        </div>

        <div class="form-group">
          <label for="apellido_paterno">Apellido Paterno <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-user"></i>
            <input type="text" id="apellido_paterno" class="form-control" placeholder="Ingresa tu apellido paterno" maxlength="50" required readonly />
          </div>
          <span class="error-message">El apellido paterno es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="apellido_materno">Apellido Materno <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-user"></i>
            <input type="text" id="apellido_materno" class="form-control" placeholder="Ingresa tu apellido materno" maxlength="50" required readonly />
          </div>
          <span class="error-message">El apellido materno es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="nombres">Nombres <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-user-circle"></i>
            <input type="text" id="nombres" class="form-control" placeholder="Ingresa tus nombres" maxlength="100" required readonly />
          </div>
          <span class="error-message">Los nombres son obligatorios</span>
        </div>

        <div class="form-group">
          <label for="fechaNacimiento">Fecha de Nacimiento <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-calendar"></i>
            <input type="date" id="fechaNacimiento" class="form-control" required style="padding-left: 3rem;" />
          </div>
          <span class="error-message">La fecha de nacimiento es obligatoria</span>
        </div>

        <div class="form-group">
          <label for="genero">Género <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-venus-mars"></i>
            <input type="text" id="genero" class="form-control" required readonly placeholder="Género" />
          </div>
          <span class="error-message">El género es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="direccion">Dirección <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-map-marker-alt"></i>
            <input type="text" id="direccion" class="form-control" placeholder="Ingresa tu dirección completa" maxlength="200" required readonly />
          </div>
          <span class="error-message">La dirección es obligatoria</span>
        </div>

        <div class="form-group">
          <label for="ubigeo">Ubigeo <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-map-pin"></i>
            <input type="text" id="ubigeo" class="form-control" placeholder="Código de ubigeo (6 dígitos)" maxlength="6" pattern="[0-9]{6}" required readonly />
          </div>
          <span class="error-message">El ubigeo debe tener 6 dígitos</span>
        </div>

        <div class="form-group">
          <label for="distrito">Distrito <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-city"></i>
            <input type="text" id="distrito" class="form-control" placeholder="Ingresa tu distrito" maxlength="100" required readonly />
          </div>
          <span class="error-message">El distrito es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="provincia">Provincia <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-building"></i>
            <input type="text" id="provincia" class="form-control" placeholder="Ingresa tu provincia" maxlength="100" required readonly />
          </div>
          <span class="error-message">La provincia es obligatoria</span>
        </div>

        <div class="form-group">
          <label for="departamento">Departamento <span class="required">*</span></label>
          <div class="input-icon">
            <i class="fas fa-map"></i>
            <input type="text" id="departamento" class="form-control" placeholder="Ingresa tu departamento" maxlength="100" required readonly />
          </div>
          <span class="error-message">El departamento es obligatorio</span>
        </div>

        <div class="form-group">
          <label for="captcha">Código de Verificación <span class="required">*</span></label>
          <div style="margin-bottom: 1rem; display: flex; gap: 1rem; align-items: center;">
            <canvas id="captchaCanvas" width="160" height="50" style="border: 2px solid var(--border-color); border-radius: 8px; background: white;"></canvas>
            <button type="button" id="refreshCaptchaBtn" class="btn btn-secondary" style="padding: 0.5rem 1rem;">
              <i class="fas fa-sync-alt"></i> Recargar
            </button>
          </div>
          <div class="input-icon">
            <i class="fas fa-lock"></i>
            <input type="text" id="captcha" class="form-control" placeholder="Ingresa el código captcha" maxlength="6" required autocomplete="off" style="text-transform: uppercase;" />
          </div>
          <span class="error-message" id="captchaError">El código captcha es incorrecto</span>
        </div>

        <!-- ===== CAMPO DE CÁMARA ===== -->
        <div class="form-group">
          <label for="fotoDni">
            Foto de Verificación <span class="required">*</span>
          </label>
          <div style="margin-bottom: 1rem;">
            <button type="button" class="btn btn-secondary" id="btnHabilitarCamara">
              <i class="fas fa-camera"></i> Habilitar Cámara
            </button>
          </div>
          <div class="photo-preview-container" id="photoPreviewContainer" style="display: none;">
            <img id="photoPreview" class="photo-preview-image" src="" alt="Foto capturada">
            <div class="photo-info">
              <span style="color: var(--success-color); font-weight: 600;">
                <i class="fas fa-check-circle"></i> Foto capturada correctamente
              </span>
              <button type="button" class="btn-retake btn-camera" id="btnRetomar">
                <i class="fas fa-redo"></i> Tomar otra foto
              </button>
            </div>
          </div>
          <input type="hidden" id="fotoDniBase64" name="fotoDni" />
          <span class="error-message" id="cameraError">Debe tomar una foto para continuar</span>
        </div>

        <!-- ===== MODAL DE CÁMARA ===== -->
        <div class="camera-modal" id="cameraModal" style="display: none;">
          <div class="camera-container">
            <div class="camera-header">
              <h3><i class="fas fa-camera"></i> Captura de Foto</h3>
              <div class="camera-instructions">
                <i class="fas fa-info-circle"></i> Presiona <strong>ESC</strong> o el botón de captura para tomar la foto y cerrar la cámara
              </div>
            </div>
            <video id="cameraVideo" autoplay playsinline></video>
            <canvas id="cameraCanvasHidden" style="display:none;"></canvas>
            <div class="camera-controls">
              <button type="button" class="btn-camera" id="btnCapturarFoto" style="background: var(--accent-green); color: white;">
                <i class="fas fa-camera"></i> Capturar Foto
              </button>
              <button type="button" class="btn-camera btn-camera-close" id="btnCerrarCamara">
                <i class="fas fa-times"></i> Cerrar
              </button>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <a href="/" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver
          </a>
          <button type="submit" class="btn btn-primary">
            Siguiente <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase/client';
    declare const faceapi: any;

    // 1. CAPTCHA GENERATOR
    const canvas = document.getElementById('captchaCanvas') as HTMLCanvasElement;
    const refreshBtn = document.getElementById('refreshCaptchaBtn');
    let currentCaptchaText = '';

    const generateCaptcha = () => {
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Background noise
      ctx.fillStyle = '#f3f4f6';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      
      // Random text
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      let captcha = '';
      for (let i = 0; i < 6; i++) {
        captcha += chars.charAt(Math.floor(Math.random() * chars.length));
      }
      currentCaptchaText = captcha;

      // Draw random lines
      ctx.strokeStyle = '#cbd5e1';
      for (let i = 0; i < 6; i++) {
        ctx.beginPath();
        ctx.moveTo(Math.random() * canvas.width, Math.random() * canvas.height);
        ctx.lineTo(Math.random() * canvas.width, Math.random() * canvas.height);
        ctx.stroke();
      }

      // Draw text
      ctx.font = 'bold 24px monospace';
      ctx.textBaseline = 'middle';
      for (let i = 0; i < captcha.length; i++) {
        ctx.fillStyle = ['#1a472a', '#28a745', '#3b82f6', '#856404'][Math.floor(Math.random() * 4)];
        ctx.save();
        ctx.translate(20 + i * 22, canvas.height / 2 + (Math.random() * 8 - 4));
        ctx.rotate((Math.random() * 20 - 10) * Math.PI / 180);
        ctx.fillText(captcha[i], 0, 0);
        ctx.restore();
      }
    };

    refreshBtn?.addEventListener('click', generateCaptcha);
    generateCaptcha();

    // 2. DNI LOOKUP
    const dniInput = document.getElementById('dni') as HTMLInputElement;
    const spinner = document.getElementById('dniSpinner');
    const dniError = document.getElementById('dniError');
    const dniSuccess = document.getElementById('dniSuccess');

    let typingTimer: any;
    const doneTypingInterval = 700;

    dniInput?.addEventListener('input', () => {
      dniInput.value = dniInput.value.replace(/\D/g, ''); // numbers only
      if (dniError) dniError.style.display = 'none';
      if (dniSuccess) dniSuccess.style.display = 'none';
      clearTimeout(typingTimer);
      
      if (dniInput.value.length === 8) {
        typingTimer = setTimeout(consultarDni, doneTypingInterval);
      }
    });

    const consultarDni = async () => {
      const dni = dniInput.value;
      try {
        if (spinner) spinner.style.display = 'block';
        dniInput.disabled = true;

        const response = await fetch(`/api/consultar-dni/${dni}`);
        const result = await response.json();

        if (result.success && result.data) {
          autocompletarCampos(result.data);
          if (dniSuccess) dniSuccess.style.display = 'block';
        } else {
          throw new Error(result.message || 'DNI no encontrado');
        }

      } catch (err: any) {
        if (dniError) {
          dniError.textContent = err.message || 'Error al validar el DNI';
          dniError.style.display = 'block';
        }
        limpiarCampos();
      } finally {
        if (spinner) spinner.style.display = 'none';
        dniInput.disabled = false;
      }
    };

    const autocompletarCampos = (data: any) => {
      const mapeo = [
        { id: 'nombres', val: data.nombres },
        { id: 'apellido_paterno', val: data.apellido_paterno },
        { id: 'apellido_materno', val: data.apellido_materno },
        { id: 'fechaNacimiento', val: data.fecha_nacimiento },
        { id: 'genero', val: data.sexo ? (data.sexo === 'M' ? 'MASCULINO' : 'FEMENINO') : '' },
        { id: 'direccion', val: data.direccion },
        { id: 'ubigeo', val: data.ubigeo_reniec || data.ubigeo_sunat },
        { id: 'distrito', val: data.distrito },
        { id: 'provincia', val: data.provincia },
        { id: 'departamento', val: data.departamento }
      ];

      mapeo.forEach(item => {
        const field = document.getElementById(item.id) as HTMLInputElement;
        if (field) {
          field.value = item.val || '';
          if (!item.val) {
            field.removeAttribute('readonly');
            field.style.border = '2px solid var(--accent-yellow)';
            field.placeholder = 'Por favor complete este campo';
          } else {
            if (item.id !== 'fechaNacimiento') {
              field.setAttribute('readonly', 'true');
              field.style.border = '';
            }
          }
        }
      });
    };

    const limpiarCampos = () => {
      ['nombres', 'apellido_paterno', 'apellido_materno', 'fechaNacimiento', 'genero', 'direccion', 'ubigeo', 'distrito', 'provincia', 'departamento'].forEach(id => {
        const field = document.getElementById(id) as HTMLInputElement;
        if (field) field.value = '';
      });
    };

    // 3. CAMERA LOGIC
    const btnHabilitarCamara = document.getElementById('btnHabilitarCamara');
    const btnCerrarCamara = document.getElementById('btnCerrarCamara');
    const btnCapturarFoto = document.getElementById('btnCapturarFoto');
    const btnRetomar = document.getElementById('btnRetomar');
    const cameraModal = document.getElementById('cameraModal');
    const video = document.getElementById('cameraVideo') as HTMLVideoElement;
    const photoCanvas = document.getElementById('cameraCanvasHidden') as HTMLCanvasElement;
    const previewContainer = document.getElementById('photoPreviewContainer');
    const previewImage = document.getElementById('photoPreview') as HTMLImageElement;
    const base64Input = document.getElementById('fotoDniBase64') as HTMLInputElement;

    let stream: MediaStream | null = null;
    let modelsLoaded = false;

    // Cargar modelos de IA para detectar rostros
    const loadModels = async () => {
      if (modelsLoaded) return;
      try {
        if (btnCapturarFoto) {
           btnCapturarFoto.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cargando IA...';
           (btnCapturarFoto as HTMLButtonElement).disabled = true;
        }
        await faceapi.nets.tinyFaceDetector.loadFromUri('https://vladmandic.github.io/face-api/model/');
        modelsLoaded = true;
        if (btnCapturarFoto) {
           btnCapturarFoto.innerHTML = '<i class="fas fa-camera"></i> Capturar Foto';
           (btnCapturarFoto as HTMLButtonElement).disabled = false;
        }
      } catch (err) {
        console.error("Error al cargar modelos de face-api", err);
        if (btnCapturarFoto) {
           btnCapturarFoto.innerHTML = '<i class="fas fa-camera"></i> Capturar Foto';
           (btnCapturarFoto as HTMLButtonElement).disabled = false;
        }
      }
    };

    btnHabilitarCamara?.addEventListener('click', async () => {
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 640 } }
        });
        if (video) video.srcObject = stream;
        if (cameraModal) cameraModal.style.display = 'flex';
        
        loadModels(); // Iniciar carga de modelos en segundo plano
      } catch (err) {
        alert('No se pudo acceder a la cámara. Por favor verifica los permisos de tu navegador.');
      }
    });

    const stopCamera = () => {
      if (stream) {
        stream.getTracks().forEach(track => track.stop());
        stream = null;
      }
      if (cameraModal) cameraModal.style.display = 'none';
      if (video) video.srcObject = null;
    };

    btnCerrarCamara?.addEventListener('click', stopCamera);

    const capturePhoto = async () => {
      if (!photoCanvas || !video) return;

      if (btnCapturarFoto) {
        btnCapturarFoto.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Analizando rostro...';
        (btnCapturarFoto as HTMLButtonElement).disabled = true;
      }

      const ctx = photoCanvas.getContext('2d');
      if (!ctx) return;

      photoCanvas.width = video.videoWidth;
      photoCanvas.height = video.videoHeight;
      
      // Draw mirrored image (standard selfie perspective)
      ctx.translate(photoCanvas.width, 0);
      ctx.scale(-1, 1);
      ctx.drawImage(video, 0, 0, photoCanvas.width, photoCanvas.height);
      
      // VALIDACIÓN FACIAL
      let faceDetected = true; // Por defecto true por si falla la carga de modelos
      if (typeof faceapi !== 'undefined' && modelsLoaded) {
        try {
          const detection = await faceapi.detectSingleFace(photoCanvas, new faceapi.TinyFaceDetectorOptions({ inputSize: 224, scoreThreshold: 0.3 }));
          if (!detection) {
            faceDetected = false;
          }
        } catch(e) {
          console.error("Error en detección facial", e);
        }
      }

      if (!faceDetected) {
        alert("¡Alerta! No se ha detectado un rostro humano en la imagen. Por favor, asegúrate de mirar a la cámara e intenta de nuevo.");
        if (btnCapturarFoto) {
          btnCapturarFoto.innerHTML = '<i class="fas fa-camera"></i> Capturar Foto';
          (btnCapturarFoto as HTMLButtonElement).disabled = false;
        }
        return; // Detener el proceso y no guardar la foto
      }

      const base64 = photoCanvas.toDataURL('image/jpeg', 0.85);
      
      if (base64Input) base64Input.value = base64;
      if (previewImage) previewImage.src = base64;
      if (previewContainer) previewContainer.style.display = 'block';
      if (btnHabilitarCamara) btnHabilitarCamara.style.display = 'none';
      
      if (btnCapturarFoto) {
        btnCapturarFoto.innerHTML = '<i class="fas fa-camera"></i> Capturar Foto';
        (btnCapturarFoto as HTMLButtonElement).disabled = false;
      }

      stopCamera();
    };

    btnCapturarFoto?.addEventListener('click', capturePhoto);

    // Capture with ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && cameraModal && cameraModal.style.display === 'flex') {
        capturePhoto();
      }
    });

    btnRetomar?.addEventListener('click', () => {
      if (base64Input) base64Input.value = '';
      if (previewImage) previewImage.src = '';
      if (previewContainer) previewContainer.style.display = 'none';
      if (btnHabilitarCamara) btnHabilitarCamara.style.display = 'inline-block';
    });

    // 4. SUBMIT FORM
    const form = document.getElementById('dniForm') as HTMLFormElement;
    const captchaInput = document.getElementById('captcha') as HTMLInputElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const captchaVal = captchaInput.value.toUpperCase();
      const photoVal = base64Input.value;
      const dni = dniInput.value;

      if (captchaVal !== currentCaptchaText) {
        alert('Código Captcha incorrecto. Intenta de nuevo.');
        generateCaptcha();
        return;
      }

      if (!photoVal) {
        alert('Debe tomar su foto de verificación facial para continuar.');
        return;
      }

      try {
        const payload = {
          dni,
          apellido_paterno: (document.getElementById('apellido_paterno') as HTMLInputElement).value,
          apellido_materno: (document.getElementById('apellido_materno') as HTMLInputElement).value,
          nombres: (document.getElementById('nombres') as HTMLInputElement).value,
          fecha_nacimiento: (document.getElementById('fechaNacimiento') as HTMLInputElement).value,
          genero: (document.getElementById('genero') as HTMLInputElement).value,
          direccion: (document.getElementById('direccion') as HTMLInputElement).value,
          ubigeo: (document.getElementById('ubigeo') as HTMLInputElement).value,
          distrito: (document.getElementById('distrito') as HTMLInputElement).value,
          provincia: (document.getElementById('provincia') as HTMLInputElement).value,
          departamento: (document.getElementById('departamento') as HTMLInputElement).value,
          foto_dni: photoVal
        };

        // Save DNI verification in Supabase
        const { error } = await supabase
          .from('solicitudes_dni')
          .upsert(payload);

        if (error) {
          throw new Error(`Error al registrar DNI: ${error.message}`);
        }

        // Save DNI in session for step progression
        sessionStorage.setItem('dni_tramite', dni);
        sessionStorage.setItem('nombre_tramite', `${payload.apellido_paterno} ${payload.apellido_materno} ${payload.nombres}`);
        
        window.location.href = '/licencia';

      } catch (err: any) {
        alert(`Ocurrió un error: ${err.message}`);
      }
    });
  </script>

  <style>
    .container {
      max-width: 700px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
    }

    .breadcrumb a {
      color: var(--accent-green);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .breadcrumb a:hover {
      color: #218838;
    }

    .form-card {
      background-color: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 2.5rem;
      box-shadow: var(--shadow);
      animation: fadeInUp 0.6s ease;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .form-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--border-color);
    }

    .form-header .icon {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, var(--accent-green), #218838);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
    }

    .form-header .icon i {
      font-size: 2rem;
      color: white;
    }

    .form-header h1 {
      font-size: 1.75rem;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .form-header p {
      color: var(--text-secondary);
      font-size: 1rem;
    }

    .form-group {
      margin-bottom: 1.5rem;
      position: relative;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 600;
      font-size: 0.95rem;
    }

    .form-group label .required {
      color: var(--error-color);
      margin-left: 0.25rem;
    }

    .input-icon {
      position: relative;
    }

    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
